<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>HopÉir</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>project_alpha</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.919318565310-hli26m79lt113fhdkud5jbjo8o1obflm</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	
	<!-- 🔔 NOTIFICATION CONFIGURATION -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
	
	<!-- ✅ REQUIRED: Background modes for notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	
	<!-- ✅ REQUIRED: Notification permission description -->
	<key>NSUserNotificationUsageDescription</key>
	<string>HopÉir uses notifications to alert you about ride updates, driver locations, and important ride information.</string>
	
	<!-- ✅ Alternative notification permission description (iOS 14+) -->
	<key>NSNotificationUsageDescription</key>
	<string>HopÉir uses notifications to keep you updated about your rides.</string>
	
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>google</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	
	<!-- 🔐 BIOMETRIC PERMISSION -->
	<key>NSFaceIDUsageDescription</key>
	<string>This app uses Face ID to sign in quickly and securely.</string>
	
	<!-- 🌐 LOCAL NETWORK PERMISSION -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>This app uses the local network for debugging and development purposes.</string>
	
	<!-- 📍 LOCATION PERMISSIONS -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>HopÉir needs your location to find nearby rides and track your driver in real-time.</string>
	
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>HopÉir needs your location to share live location during an ongoing ride.</string>
	
	<key>NSLocationAlwaysUsageDescription</key>
	<string>HopÉir needs your location to track your driver in real-time during rides.</string>
	

	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIStatusBarHidden</key>
	<false/>

	<!-- 📱 ORIENTATION -->
	<key>UISupportedInterfaceOrientations~iphone</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	
	<!-- 🔔 REQUIRED: Remote notification support -->
	<key>UIRemoteNotifications</key>
	<true/>
	
	<!-- ✅ Push notification support -->
	<key>UIApplicationLaunchOptionsRemoteNotificationKey</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
</dict>
</plist>
